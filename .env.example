# Aliyun RDS MySQL connection.
# Copy to .env and fill real values locally or add them as deployment secrets.
OCTOPUS_RDS_HOST=
OCTOPUS_RDS_PORT=3306
OCTOPUS_RDS_USER=
OCTOPUS_RDS_PASSWORD=
OCTOPUS_RDS_DATABASE=
OCTOPUS_RDS_CHARSET=utf8mb4
OCTOPUS_RDS_CONNECT_TIMEOUT=10

# Optional. Set only if SSL is enabled and you want to verify with a CA file.
OCTOPUS_RDS_SSL_CA=

# Supabase source for managed Octopus scraper configs and scrape logs.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional scraper/provider credentials. These names match ahaIndexSync where
# the underlying scraper uses the same provider.
GH_MODELS_TOKEN=
KIMI_API_KEY=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
TWITTERAPI_IO_KEY=
PRODUCTHUNT_TOKEN=
